# ============================================
# Xat Environment Variables
# Copy this file to .env and configure values
# ============================================

# --- Database ---
DATABASE_URL=postgresql://xat:xat@localhost:5432/xat
POSTGRES_USER=xat
POSTGRES_PASSWORD=xat
POSTGRES_DB=xat

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- S3 / MinIO ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=xat-uploads
S3_REGION=us-east-1

# --- App ---
PORT=3000
PUBLIC_APP_URL=http://localhost:3000
SESSION_SECRET=change-me-to-a-random-string

# --- Email ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@xat.app

# --- AI ---
OPENAI_API_KEY=

# --- Integrations ---
DYTE_ORG_ID=
DYTE_API_KEY=

# --- Push Notifications (Web Push / VAPID) ---
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@xat.app

# --- Twilio (SMS + Voice) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- Calendar: Google OAuth (Calendar + Meet) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Calendar: Microsoft Outlook OAuth ---
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Calendar: Zoom OAuth ---
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
